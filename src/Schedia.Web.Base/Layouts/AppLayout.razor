@using Avemepls.Blazor.Components
@using Microsoft.Extensions.Localization
@using Color = MudBlazor.Color
@inherits LayoutComponentBase
@inject IStringLocalizer<AppLayout> Loc

<MudLayout>
    <MudAppBar Color="Color.Primary" Fixed="false">
        <MudText Typo="Typo.h6">Schedia</MudText>
        <MudSpacer />

        <LanguageSwitcher Color="Color.Inherit" />

        <AuthorizeView>
            <Authorized>
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit">
                    <MudMenuItem Icon="@Icons.Material.Filled.Settings">@("Настройки".Loc(Loc))</MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="@Logout">
                        @("Выйти".Loc(Loc))
                    </MudMenuItem>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/login" Variant="Variant.Text" Color="Color.Inherit">
                    @("Войти".Loc(Loc))
                </MudButton>
                <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Secondary">
                    @("Регистрация".Loc(Loc))
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudMainContent Style="min-height: 100vh; padding-top: 0;">
        <div class="pa-4">
            @Body
        </div>
    </MudMainContent>
</MudLayout>

@code {
    [Inject]
    private IAuthenticationService AuthService { get; set; } = default!;

    private async Task Logout() => await AuthService.LogoutAsync();
}
