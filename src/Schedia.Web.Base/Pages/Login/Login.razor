@page "/login"
@layout AnonymousLayout
@attribute [AllowAnonymous]
@inherits MediatorComponentBase
@using Avemepls.Blazor.Common
@using Avemepls.Blazor.Components
@using Microsoft.AspNetCore.Authorization
@using Schedia.Web.Base.Layouts
@inject IAuthenticationService AuthService
@inject Schedia.Web.Base.Services.IPlatformService PlatformService

<AuthorizeView>
    <Authorized>
        <RedirectToHome />
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height: 100vh;">
            <MudCard Style="max-width: 400px; width: 100%; padding: 20px;">
                <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-4">@("Вход".Loc(Loc))</MudText>

                <MudForm Model="@_model" @ref="@_form" Validation="@(_authValidator.ValidateValue)">

                    <BaseTextField T="string"
                                   @bind-Value="_model.Username"
                                   For="@(() => _model.Username)"
                                   Label="@("Имя пользователя".Loc(Loc))" />

                    <BaseTextField T="string"
                                   @bind-Value="_model.Password"
                                   For="@(() => _model.Password)"
                                   Label="@("Пароль".Loc(Loc))"
                                   InputType="InputType.Password" />
                </MudForm>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@ErrorMessage</MudAlert>
                }

                @if (!string.IsNullOrEmpty(AdditionalInformationAsWarning))
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-4">@AdditionalInformationAsWarning</MudAlert>
                }

                <MudButton ButtonType="ButtonType.Button"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="@(_isLoading)"
                           OnClick="@(async () => await HandleLogin())"
                           Class="mb-4">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                        <MudText Class="ml-2">@("Загрузка".Loc(Loc))...</MudText>
                    }
                    else
                    {
                        <text>@("Войти".Loc(Loc))</text>
                    }
                </MudButton>

                @if (PlatformService.IsWeb)
                {
                    <div class="d-flex align-center my-2" style="gap: 8px;">
                        <hr style="flex: 1; border: none; border-top: 1px solid var(--mud-palette-lines-default);" />
                        <MudText Typo="Typo.body2" Style="white-space: nowrap; color: var(--mud-palette-text-secondary);">
                            @("или".Loc(Loc))
                        </MudText>
                        <hr style="flex: 1; border: none; border-top: 1px solid var(--mud-palette-lines-default);" />
                    </div>

                    <MudButton Href="@GetGoogleLoginUrl()"
                               Variant="Variant.Outlined"
                               FullWidth="true"
                               Class="mb-4"
                               StartIcon="@GoogleIcon">
                        @("Войти через Google".Loc(Loc))
                    </MudButton>
                }

                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <div>@("Еще не зарегистрированы?".Loc(Loc))
                        <MudLink Href="/register" Color="Color.Primary">@("Регистрация".Loc(Loc))</MudLink>
                    </div>
                    <MudLink Href="/forgot-password" Color="Color.Primary">@("Забыли пароль?".Loc(Loc))</MudLink>
                </MudStack>
            </MudCard>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

@code {
    private const string GoogleIcon = @"<svg xmlns=""http://www.w3.org/2000/svg"" viewBox=""0 0 48 48"" width=""24"" height=""24""><path fill=""#4285F4"" d=""M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z""/><path fill=""#34A853"" d=""M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z""/><path fill=""#FBBC05"" d=""M10.53 28.59A14.5 14.5 0 0 1 9.5 24c0-1.59.28-3.14.76-4.59l-7.98-6.19A23.99 23.99 0 0 0 0 24c0 3.77.9 7.35 2.56 10.53l7.97-5.94z""/><path fill=""#EA4335"" d=""M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 5.94C6.51 42.62 14.62 48 24 48z""/></svg>";

    private readonly Avemepls.Auth.Domain.ViaPassword.Login.Command _model = new();
    private bool _isLoading;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private readonly Avemepls.Auth.Domain.ViaPassword.Login.Validator _authValidator = new();

    private MudForm _form = null!;

    private async Task HandleLogin()
    {
        _isLoading = true;
        await _form.Validate();
        _isLoading = false;

        if (!_form.IsValid)
        {
            return;
        }

        ErrorMessage = "";
        var tokenInformation = await Send(new Avemepls.Auth.Domain.ViaPassword.Login.Command()
        {
            Username = _model.Username,
            Password = _model.Password
        });

        if (tokenInformation is null)
        {
            return;
        }

        await AuthService.LoginAsync(tokenInformation, ReturnUrl);
    }

    private string GetGoogleLoginUrl()
    {
        var returnUrl = Uri.EscapeDataString(ReturnUrl ?? "/");
        return $"/api/auth/google-login?returnUrl={returnUrl}";
    }
}
