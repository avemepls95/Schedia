@page "/register"
@layout AnonymousLayout
@attribute [AllowAnonymous]
@using Avemepls.Blazor.Components
@using Microsoft.AspNetCore.Authorization
@using Avemepls.Identity.DataAccess
@using Microsoft.EntityFrameworkCore
@using Schedia.Web.Base.Layouts
@using FluentValidation
@using Microsoft.Extensions.Localization
@using Schedia.Auth.Domain.Validators
@inject IMediator Mediator
@inject IAuthenticationService AuthService
@inject IDbContextFactory<IdentityDbContext> DbContextFactory
@inject IStringLocalizer<Validator> ValidatorLoc
@inject IStringLocalizer<Register> Loc
@inject IStringLocalizer<PasswordValidator> PasswordValidatorLoc

<AuthorizeView>
    <Authorized>
        <RedirectToHome />
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height: 100vh;">
            <MudCard Style="max-width: 400px; width: 100%; padding: 20px;">
                <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-4">@("Регистрация".Loc(Loc))</MudText>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <MudAlert Severity="MudBlazor.Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
                }

                <MudForm Model="@_model" @ref="@_form" Validation="@(_authValidator.ValidateValue)">

                    <BaseTextField T="string"
                                   @bind-Value="_model.Username"
                                   Label="@("Имя пользователя".Loc(Loc))"
                                   For="@(() => _model.Username)" />

                    <BaseTextField T="string"
                                   @bind-Value="_model.Email"
                                   Label="@("Электронная почта".Loc(Loc))"
                                   For="@(() => _model.Email)" />

                    <BaseTextField T="string"
                                   @bind-Value="_model.Password"
                                   Label="@("Пароль".Loc(Loc))"
                                   InputType="InputType.Password"
                                   For="@(() => _model.Password)" />

                    <BaseTextField T="string"
                                   @bind-Value="_model.ConfirmPassword"
                                   Label="@("Подтвердите пароль".Loc(Loc))"
                                   InputType="InputType.Password"
                                   For="@(() => _model.ConfirmPassword)" />
                </MudForm>

                <MudButton ButtonType="ButtonType.Button"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="@(_isLoading)"
                           OnClick="@(async () => await HandleRegister())"
                           Class="mb-4">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                        <MudText Class="ml-2">@("Загрузка".Loc(Loc))...</MudText>
                    }
                    else
                    {
                        <text>@("Регистрация".Loc(Loc))</text>
                    }
                </MudButton>

                <MudText Align="Align.Center">
                    @("Уже зарегистрированы?".Loc(Loc)) <MudLink Href="/login" Color="Color.Primary">@("Войти".Loc(Loc))</MudLink>
                </MudText>
            </MudCard>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

@code {
    private readonly Command _model = new();
    private bool _isLoading;
    private string _errorMessage = "";

    private Validator _authValidator = null!;

    private MudForm _form = null!;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _authValidator = new Validator(DbContextFactory, ValidatorLoc, PasswordValidatorLoc);
    }

    private async Task HandleRegister()
    {
        _isLoading = true;
        await _form.Validate();
        _isLoading = false;
        if (!_form.IsValid)
        {
            return;
        }

        _errorMessage = "";

        try
        {
            var tokenInformation = await Mediator.Send(new Auth.Domain.ViaPassword.Register.Command
            {
                Username = _model.Username,
                Email = _model.Email,
                Password = _model.Password
            });

            await AuthService.LoginAsync(tokenInformation);
        }
        catch (Exception ex)
        {
            _errorMessage = Loc["Произошла непредвиденная ошибка"];
            Console.WriteLine(ex.Message);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    public class Command : Auth.Domain.ViaPassword.Register.Command
    {
        public string? ConfirmPassword { get; set; }
    }

    public class Validator : Auth.Domain.ViaPassword.Register.Validator<Command>
    {
        public Validator(
            IDbContextFactory<IdentityDbContext> dbContextFactory,
            IStringLocalizer<Auth.Domain.ViaPassword.Register.Validator<Command>> loc,
            IStringLocalizer<PasswordValidator> passwordLoc)
            : base(dbContextFactory, loc, passwordLoc)
        {
            RuleFor(x => x.ConfirmPassword)
                .Equal(x => x.Password)
                .WithMessage(loc["Пароли не совпадают"]);
        }
    }
}
