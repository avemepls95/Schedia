@page "/reset-password"
@layout AnonymousLayout
@attribute [AllowAnonymous]
@inherits MediatorComponentBase
@using Avemepls.Blazor.Common
@using Avemepls.Blazor.Components
@using Avemepls.Identity.DataAccess
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Schedia.Web.Base.Layouts
@using Severity = MudBlazor.Severity
@using FluentValidation
@using Microsoft.Extensions.Localization
@using Schedia.Auth.Domain.Validators
@inject NavigationManager NavManager
@inject IDbContextFactory<IdentityDbContext> DbContextFactory
@inject IStringLocalizer<Validator> ValidatorLoc
@inject IStringLocalizer<PasswordValidator> PasswordValidatorLoc

<AuthorizeView>
    <Authorized>
        <RedirectToHome/>
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height: 100vh;">
            <MudCard Style="max-width: 400px; width: 100%; padding: 20px;">
                @if (!_passwordReset)
                {
                    <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-4">@("Установить новый пароль".Loc(Loc))</MudText>
                    <MudForm @ref="@_form" Model="@_model" Validation="@(_validator.ValidateValue)">

                        <BaseTextField T="string"
                                       @bind-Value="_model.NewPassword"
                                       For="@(() => _model.NewPassword)"
                                       Label="@("Новый пароль".Loc(Loc))"
                                       InputType="InputType.Password"/>

                        <BaseTextField T="string"
                                       @bind-Value="_model.ConfirmPassword"
                                       For="@(() => _model.ConfirmPassword)"
                                       Label="@("Подтвердите пароль".Loc(Loc))"
                                       InputType="InputType.Password"/>

                        @if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <MudAlert Severity="Severity.Error" Class="mb-4">@ErrorMessage</MudAlert>
                        }

                        @if (!string.IsNullOrEmpty(AdditionalInformationAsWarning))
                        {
                            <MudAlert Severity="Severity.Warning" Class="mb-4">@AdditionalInformationAsWarning</MudAlert>
                        }

                        <MudButton ButtonType="ButtonType.Button"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Disabled="@(_isLoading)"
                                   OnClick="@(async () => await HandleSubmit())"
                                   Class="mb-4">
                            @if (_isLoading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                                <MudText Class="ml-2">@("Загрузка".Loc(Loc))...</MudText>
                            }
                            else
                            {
                                <text>@("Сбросить пароль".Loc(Loc))</text>
                            }
                        </MudButton>
                    </MudForm>
                }
                else
                {
                    <div style="text-align: center;">
                        <div style="margin-bottom: 16px; font-size: 48px; color: #52c41a;">✓</div>
                        <h3>@("Пароль успешно сброшен".Loc(Loc))</h3>
                        <p>@("Ваш пароль изменен. Теперь вы можете войти с новым паролем".Loc(Loc))</p>
                        <button @onclick="@(() => NavManager.NavigateTo("/login"))"
                                style="margin-top: 16px; padding: 10px 20px; background: #1890ff; color: white; border: none; border-radius: 4px; cursor: pointer;">
                            @("Войти".Loc(Loc))
                        </button>
                    </div>
                }
            </MudCard>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

@code {
    private readonly Command _model = new();
    private bool _isLoading;
    private bool _passwordReset;

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private MudForm _form = null!;
    private Validator _validator = null!;

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(Token))
        {
            NavManager.NavigateTo("/forgot-password");
        }

        _validator = new Validator(DbContextFactory, ValidatorLoc, PasswordValidatorLoc);
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        await _form.Validate();
        _isLoading = false;

        if (!_form.IsValid)
        {
            return;
        }

        ErrorMessage = "";
        await Send(new Schedia.Auth.Domain.ViaPassword.ResetPassword.Command
        {
            NewPassword = _model.NewPassword,
            Token = Token!
        });

        if (string.IsNullOrWhiteSpace(ErrorMessage))
        {
            _passwordReset = true;
        }
    }

    public class Command : Auth.Domain.ViaPassword.ResetPassword.Command
    {
        public string? ConfirmPassword { get; set; }
    }

    public class Validator : Auth.Domain.ViaPassword.ResetPassword.Validator<Command>
    {
        public Validator(
            IDbContextFactory<IdentityDbContext> dbContextFactory,
            IStringLocalizer<Auth.Domain.ViaPassword.ResetPassword.Validator<Command>> loc,
            IStringLocalizer<PasswordValidator> passwordLoc) : base(dbContextFactory, loc, passwordLoc)
        {
            RuleFor(x => x.ConfirmPassword)
                .Equal(x => x.NewPassword)
                .WithMessage(loc["Пароли не совпадают"]);
        }
    }

}
