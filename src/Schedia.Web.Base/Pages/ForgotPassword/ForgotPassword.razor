@page "/forgot-password"
@layout AnonymousLayout
@attribute [AllowAnonymous]
@inherits MediatorComponentBase
@using Avemepls.Blazor.Common
@using Avemepls.Blazor.Components
@using FluentValidation
@using Microsoft.AspNetCore.Authorization
@using Avemepls.Auth.Domain.ViaPassword
@using Avemepls.Core.Extensions
@using Schedia.Web.Base.Layouts
@using Severity = MudBlazor.Severity
@inject NavigationManager NavManager
@inject IValidator<RequestPasswordReset.Command> Validator

<AuthorizeView>
    <Authorized>
        <RedirectToHome/>
    </Authorized>
    <NotAuthorized>
        <div class="forgot-password-container" style="display: flex; justify-content: center; align-items: center; min-height: 100vh">
            <MudCard Style="max-width: 400px; width: 100%; padding: 20px;">
                @if (!_emailSent)
                {
                    <MudForm Model="@_model" @ref="@_form" Validation="@(_authValidator.ValidateValue)">

                        <div style="padding: 8px; background: #e6f7ff; border: 1px solid #91d5ff; border-radius: 4px; color: #0050b3;">
                            @("Введите свой email и мы вышлем Вам ссылку для сброса пароля".Loc(Loc))
                        </div>

                        <BaseTextField T="string"
                                       @bind-Value="_model.Email"
                                       Label="@("Электронная почта".Loc(Loc))"/>

                        <MudButton ButtonType="ButtonType.Button"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Disabled="@(_isLoading)"
                                   OnClick="@(async () => await HandleSubmit())"
                                   Class="mb-4">
                            @if (_isLoading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                                <MudText Class="ml-2">@("Загрузка".Loc(Loc))...</MudText>
                            }
                            else
                            {
                                <text>@("Отправить ссылку для сброса пароля".Loc(Loc))</text>
                            }
                        </MudButton>

                        @if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <MudAlert Severity="Severity.Error" Class="mb-4">@ErrorMessage</MudAlert>
                        }

                        @if (!string.IsNullOrEmpty(AdditionalInformationAsWarning))
                        {
                            <MudAlert Severity="Severity.Warning" Class="mb-4">@AdditionalInformationAsWarning</MudAlert>
                        }

                        <MudText Align="Align.Center">
                            <MudLink Href="/login" Color="Color.Primary">@("Войти".Loc(Loc))</MudLink>
                        </MudText>
                    </MudForm>
                }
                else
                {
                    <div style="text-align: center;">
                        <div style="margin-bottom: 16px; font-size: 48px; color: #52c41a;">✓</div>
                        <h3>@("Проверьте свой почтовый ящик ({0})".Loc(Loc, _model.Email))</h3>
                        <p>@("Мы выслали на него инструкцию для сброса пароля".Loc(Loc))</p>
                        <MudButton @onclick="@(() => NavManager.NavigateTo("/login"))"
                                   Disabled="@(_isLoading)"
                                   style="margin-top: 16px; padding: 10px 20px; background: #1890ff; color: white; border: none; border-radius: 4px; cursor: pointer;">
                            @("Войти".Loc(Loc))
                        </MudButton>
                    </div>
                }
            </MudCard>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private readonly RequestPasswordReset.Command _model = new();
    private bool _isLoading;
    private bool _emailSent;

    private RequestPasswordReset.Validator _authValidator = null!;

    private MudForm _form = null!;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _authValidator = (RequestPasswordReset.Validator)Validator;
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        await _form.Validate();
        _isLoading = false;

        if (!_form.IsValid)
        {
            return;
        }

        ErrorMessage = "";
        await Send(new RequestPasswordReset.Command { Email = _model.Email });

        if (ErrorMessage.IsNullOrWhiteSpace())
        {
            _emailSent = true;
        }
    }
}
