@using System.Globalization
@using Microsoft.JSInterop
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime

<MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
    <ActivatorContent>
        <MudIconButton Color="Color">
            <img src="@CurrentFlagSrc" width="24" height="16" alt="@CurrentLabel" style="border-radius: 2px;" />
        </MudIconButton>
    </ActivatorContent>
    <ChildContent>
        <MudMenuItem OnClick="@(() => SetCultureAsync("en"))" Icon="@GetCheckIcon("en")">
            <div class="d-flex align-center gap-2">
                <img src="@FlagEnSrc" width="24" height="16" alt="EN" style="border-radius: 2px;" />
                <span>English</span>
            </div>
        </MudMenuItem>
        <MudMenuItem OnClick="@(() => SetCultureAsync("ru"))" Icon="@GetCheckIcon("ru")">
            <div class="d-flex align-center gap-2">
                <img src="@FlagRuSrc" width="24" height="16" alt="RU" style="border-radius: 2px;" />
                <span>Русский</span>
            </div>
        </MudMenuItem>
    </ChildContent>
</MudMenu>

@code {
    [Parameter] public Color Color { get; set; } = Color.Primary;

    private readonly string _currentCulture = CultureInfo.CurrentCulture.Name;

    private const string FlagRuSrc = "_content/Schedia.Web.Base/images/flags/ru.svg";
    private const string FlagEnSrc = "_content/Schedia.Web.Base/images/flags/gb.svg";

    private string CurrentFlagSrc => _currentCulture.StartsWith("ru", StringComparison.OrdinalIgnoreCase) ? FlagRuSrc : FlagEnSrc;
    private string CurrentLabel => _currentCulture.StartsWith("ru", StringComparison.OrdinalIgnoreCase) ? "RU" : "EN";

    private string? GetCheckIcon(string culture)
    {
        return _currentCulture.StartsWith(culture, StringComparison.OrdinalIgnoreCase)
            ? Icons.Material.Filled.Check
            : null;
    }

    private async Task SetCultureAsync(string culture)
    {
        if (_currentCulture.StartsWith(culture, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        // Set cookie directly in browser via JS
        var cookieValue = $"c={culture}|uic={culture}";
        await JsRuntime.InvokeVoidAsync("eval",
            $"document.cookie = 'Schedia.Culture={cookieValue}; path=/; max-age=31536000; samesite=lax'");

        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }
}