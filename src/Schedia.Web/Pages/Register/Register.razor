@page "/register"
@using System.ComponentModel.DataAnnotations
@using System.Text.RegularExpressions
@using MediatR
@inject NavigationManager NavManager
@inject IMediator Mediator

<div class="register-container" style="display: flex; justify-content: center; align-items: center; min-height: 100vh; background: #f0f2f5;">
    <Card Title="Create Account" Style="max-width: 400px; width: 100%; padding: 20px;">
        <EditForm Model="@_model" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />

            <div style="margin-bottom: 16px;">
                <label style="display: block; margin-bottom: 4px;">Username</label>
                <InputText @bind-Value="_model.Username" placeholder="Choose a username" style="width: 100%; padding: 8px; border: 1px solid #d9d9d9; border-radius: 4px;" />
                <ValidationMessage For="@(() => _model.Username)" style="color: #ff4d4f;" />
            </div>

            <div style="margin-bottom: 16px;">
                <label style="display: block; margin-bottom: 4px;">Email</label>
                <InputText @bind-Value="_model.Email" type="email" placeholder="Enter email" style="width: 100%; padding: 8px; border: 1px solid #d9d9d9; border-radius: 4px;" />
                <ValidationMessage For="@(() => _model.Email)" style="color: #ff4d4f;" />
            </div>

            <div style="margin-bottom: 16px;">
                <label style="display: block; margin-bottom: 4px;">Password</label>
                <InputText @bind-Value="_model.Password" type="password" placeholder="Choose a password" style="width: 100%; padding: 8px; border: 1px solid #d9d9d9; border-radius: 4px;" />
                <ValidationMessage For="@(() => _model.Password)" style="color: #ff4d4f;" />
            </div>

            <div style="margin-bottom: 16px;">
                <label style="display: block; margin-bottom: 4px;">Confirm Password</label>
                <InputText @bind-Value="_model.ConfirmPassword" type="password" placeholder="Confirm password" style="width: 100%; padding: 8px; border: 1px solid #d9d9d9; border-radius: 4px;" />
                <ValidationMessage For="@(() => _model.ConfirmPassword)" style="color: #ff4d4f;" />
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div style="margin-bottom: 16px; padding: 8px; background: #fff2f0; border: 1px solid #ffccc7; border-radius: 4px; color: #ff4d4f;">
                    @_errorMessage
                </div>
            }

            <div style="margin-bottom: 16px;">
                <button type="submit" disabled="@_isLoading" style="width: 100%; padding: 10px; background: #1890ff; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px;">
                    @if (_isLoading)
                    {
                        <text>Loading...</text>
                    }
                    else
                    {
                        <text>Register</text>
                    }
                </button>
            </div>

            <div style="text-align: center; margin-top: 16px;">
                <a @onclick="@(() => NavManager.NavigateTo("/login"))" style="color: #1890ff; cursor: pointer; text-decoration: underline;">Already have an account? Login</a>
            </div>
        </EditForm>
    </Card>
</div>

@code {
    private readonly RegisterModel _model = new();
    private bool _isLoading = false;
    private string _errorMessage = "";

    private async Task HandleRegister()
    {
        _isLoading = true;
        _errorMessage = "";

        try
        {
            await Mediator.Send(new Auth.Domain.ViaPassword.Register.Command
            {
                Username = _model.Username,
                Email = _model.Email,
                Password = _model.Password
            });

            NavManager.NavigateTo("/", forceLoad: true);
        }
        catch (ValidationException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            _errorMessage = "Произошла непредвиденная ошибка";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private class RegisterModel : IValidatableObject
    {
        [Required(ErrorMessage = "Username is required")]
        [StringLength(50, MinimumLength = 3, ErrorMessage = "Username must be 3-50 characters")]
        public string Username { get; set; } = "";

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email address")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password")]
        public string ConfirmPassword { get; set; } = "";

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (Password != ConfirmPassword)
            {
                yield return new ValidationResult(
                    "Passwords do not match",
                    [nameof(ConfirmPassword)]);
            }

            // Поэтапная проверка пароля
            if (string.IsNullOrEmpty(Password))
                yield break;

            if (Password.Length < 8)
                yield return new ValidationResult("Password must be at least 8 characters", [nameof(Password)]);

            if (Password.Length > 16)
                yield return new ValidationResult("Password must not exceed 16 characters", [nameof(Password)]);

            if (!Regex.IsMatch(Password, @"[a-z]"))
                yield return new ValidationResult("Must contain at least one lowercase letter", [nameof(Password)]);

            if (!Regex.IsMatch(Password, @"[A-Z]"))
                yield return new ValidationResult("Must contain at least one uppercase letter", [nameof(Password)]);

            if (!Regex.IsMatch(Password, @"\d"))
                yield return new ValidationResult("Must contain at least one number", [nameof(Password)]);
        }
    }
}
