@page "/forgot-password"
@using System.ComponentModel.DataAnnotations
@using MediatR
@using Schedia.Auth.Domain.ViaPassword
@inject IMediator Mediator
@inject NavigationManager NavManager

<div class="forgot-password-container" style="display: flex; justify-content: center; align-items: center; min-height: 100vh; background: #f0f2f5;">
    <Card Title="Reset Password" Style="max-width: 400px; width: 100%; padding: 20px;">
        @if (!_emailSent)
        {
            <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div style="margin-bottom: 16px; padding: 8px; background: #e6f7ff; border: 1px solid #91d5ff; border-radius: 4px; color: #0050b3;">
                    Enter your email address and we'll send you a link to reset your password.
                </div>

                <div style="margin-bottom: 16px;">
                    <label style="display: block; margin-bottom: 4px;">Email</label>
                    <InputText @bind-Value="_model.Email" type="email" placeholder="Enter your email" style="width: 100%; padding: 8px; border: 1px solid #d9d9d9; border-radius: 4px;" />
                    <ValidationMessage For="@(() => _model.Email)" style="color: #ff4d4f;" />
                </div>

                <div style="margin-bottom: 16px;">
                    <button type="submit" disabled="@_isLoading" style="width: 100%; padding: 10px; background: #1890ff; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px;">
                        @if (_isLoading)
                        {
                            <text>Loading...</text>
                        }
                        else
                        {
                            <text>Send Reset Link</text>
                        }
                    </button>
                </div>

                <div style="text-align: center; margin-top: 16px;">
                    <a @onclick="@(() => NavManager.NavigateTo("/login"))" style="color: #1890ff; cursor: pointer; text-decoration: underline;">Back to login</a>
                </div>
            </EditForm>
        }
        else
        {
            <div style="text-align: center;">
                <div style="margin-bottom: 16px; font-size: 48px; color: #52c41a;">✓</div>
                <h3>Check Your Email</h3>
                <p>If an account exists with that email, we've sent password reset instructions.</p>
                <button @onclick="@(() => NavManager.NavigateTo("/login"))" style="margin-top: 16px; padding: 10px 20px; background: #1890ff; color: white; border: none; border-radius: 4px; cursor: pointer;">
                    Back to Login
                </button>
            </div>
        }
    </Card>
</div>

@code {
    private readonly ForgotPasswordModel _model = new();
    private bool _isLoading = false;
    private bool _emailSent = false;

    private async Task HandleSubmit()
    {
        _isLoading = true;

        try
        {
            await Mediator.Send(new RequestPasswordReset.Command
            {
                Email = _model.Email,
            });

            _emailSent = true;
        }
        catch (Exception ex)
        {
            _emailSent = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email address")]
        public string Email { get; set; } = "";
    }
}
