@page "/confirm-email"
@inject HttpClient Http
@inject NavigationManager NavManager

<div class="confirm-email-container" style="display: flex; justify-content: center; align-items: center; min-height: 100vh; background: #f0f2f5;">
    @if (_isLoading)
    {
        <Card Style="max-width: 500px; width: 100%; padding: 40px; text-align: center;">
            <div style="font-size: 24px; margin-bottom: 16px;">⏳</div>
            <p>Confirming your email...</p>
        </Card>
    }
    else if (_success)
    {
        <Card Style="max-width: 500px; width: 100%; padding: 40px; text-align: center;">
            <div style="font-size: 48px; color: #52c41a; margin-bottom: 16px;">✓</div>
            <h2>Email Confirmed!</h2>
            <p style="margin-bottom: 24px;">Your email address has been verified successfully.</p>
            <button @onclick="@(() => NavManager.NavigateTo("/"))" style="padding: 10px 20px; background: #1890ff; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px;">
                Go to Home
            </button>
        </Card>
    }
    else
    {
        <Card Style="max-width: 500px; width: 100%; padding: 40px; text-align: center;">
            <div style="font-size: 48px; color: #ff4d4f; margin-bottom: 16px;">✗</div>
            <h2>Confirmation Failed</h2>
            <p style="margin-bottom: 24px;">The confirmation link is invalid or has expired.</p>
            <button @onclick="@(() => NavManager.NavigateTo("/login"))" style="padding: 10px 20px; background: #1890ff; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px;">
                Back to Login
            </button>
        </Card>
    }
</div>

@code {
    private bool _isLoading = true;
    private bool _success = false;

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Token))
        {
            _isLoading = false;
            return;
        }

        try
        {
            var response = await Http.GetAsync($"/api/auth/email-confirmation?token={Uri.EscapeDataString(Token)}");
            _success = response.IsSuccessStatusCode;
        }
        catch
        {
            _success = false;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
