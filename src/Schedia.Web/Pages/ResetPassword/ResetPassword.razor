@page "/reset-password"
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavManager

<div class="reset-password-container" style="display: flex; justify-content: center; align-items: center; min-height: 100vh; background: #f0f2f5;">
    <Card Title="Set New Password" Style="max-width: 400px; width: 100%; padding: 20px;">
        @if (!_passwordReset)
        {
            <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div style="margin-bottom: 16px;">
                    <label style="display: block; margin-bottom: 4px;">New Password</label>
                    <InputText @bind-Value="_model.NewPassword" type="password" placeholder="Enter new password" style="width: 100%; padding: 8px; border: 1px solid #d9d9d9; border-radius: 4px;" />
                    <ValidationMessage For="@(() => _model.NewPassword)" style="color: #ff4d4f;" />
                </div>

                <div style="margin-bottom: 16px;">
                    <label style="display: block; margin-bottom: 4px;">Confirm Password</label>
                    <InputText @bind-Value="_model.ConfirmPassword" type="password" placeholder="Confirm new password" style="width: 100%; padding: 8px; border: 1px solid #d9d9d9; border-radius: 4px;" />
                    <ValidationMessage For="@(() => _model.ConfirmPassword)" style="color: #ff4d4f;" />
                </div>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div style="margin-bottom: 16px; padding: 8px; background: #fff2f0; border: 1px solid #ffccc7; border-radius: 4px; color: #ff4d4f;">
                        @_errorMessage
                    </div>
                }

                <div style="margin-bottom: 16px;">
                    <button type="submit" disabled="@_isLoading" style="width: 100%; padding: 10px; background: #1890ff; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px;">
                        @if (_isLoading)
                        {
                            <text>Loading...</text>
                        }
                        else
                        {
                            <text>Reset Password</text>
                        }
                    </button>
                </div>
            </EditForm>
        }
        else
        {
            <div style="text-align: center;">
                <div style="margin-bottom: 16px; font-size: 48px; color: #52c41a;">✓</div>
                <h3>Password Reset Successful</h3>
                <p>Your password has been changed. You can now log in with your new password.</p>
                <button @onclick="@(() => NavManager.NavigateTo("/login"))" style="margin-top: 16px; padding: 10px 20px; background: #1890ff; color: white; border: none; border-radius: 4px; cursor: pointer;">
                    Go to Login
                </button>
            </div>
        }
    </Card>
</div>

@code {
    private ResetPasswordModel _model = new();
    private bool _isLoading = false;
    private bool _passwordReset = false;
    private string _errorMessage = "";

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(Token))
        {
            NavManager.NavigateTo("/forgot-password");
        }
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _errorMessage = "";

        try
        {
            var response = await Http.PostAsJsonAsync("/api/auth/password-reset/confirm", new
            {
                Token,
                _model.NewPassword
            });

            if (response.IsSuccessStatusCode)
            {
                _passwordReset = true;
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _errorMessage = error?.Message ?? "Password reset failed. The link may have expired.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "An error occurred";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private class ResetPasswordModel : IValidatableObject
    {
        [Required(ErrorMessage = "Password is required")]
        [StringLength(100, MinimumLength = 8, ErrorMessage = "Password must be at least 8 characters")]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password")]
        public string ConfirmPassword { get; set; } = "";

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (NewPassword != ConfirmPassword)
            {
                yield return new ValidationResult(
                    "Passwords do not match",
                    [nameof(ConfirmPassword)]);
            }
        }
    }

    private record ErrorResponse(string Message);
}
