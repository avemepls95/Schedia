@page "/login"
@using System.ComponentModel.DataAnnotations
@using MediatR
@using Schedia.Auth.Domain.ViaPassword
@inject NavigationManager NavManager
@inject IMediator Mediator

<div class="login-container" style="display: flex; justify-content: center; align-items: center; min-height: 100vh; background: #f0f2f5;">
    <Card Title="Login" Style="max-width: 400px; width: 100%; padding: 20px;">
        <EditForm Model="@_model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div style="margin-bottom: 16px;">
                <label style="display: block; margin-bottom: 4px;">Username</label>
                <InputText @bind-Value="_model.Username" placeholder="Enter username" style="width: 100%; padding: 8px; border: 1px solid #d9d9d9; border-radius: 4px;" />
                <ValidationMessage For="@(() => _model.Username)" style="color: #ff4d4f;" />
            </div>

            <div style="margin-bottom: 16px;">
                <label style="display: block; margin-bottom: 4px;">Password</label>
                <InputText @bind-Value="_model.Password" type="password" placeholder="Enter password" style="width: 100%; padding: 8px; border: 1px solid #d9d9d9; border-radius: 4px;" />
                <ValidationMessage For="@(() => _model.Password)" style="color: #ff4d4f;" />
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div style="margin-bottom: 16px; padding: 8px; background: #fff2f0; border: 1px solid #ffccc7; border-radius: 4px; color: #ff4d4f;">
                    @_errorMessage
                </div>
            }

            <div style="margin-bottom: 16px;">
                <button type="submit" disabled="@_isLoading" style="width: 100%; padding: 10px; background: #1890ff; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px;">
                    @if (_isLoading)
                    {
                        <text>Loading...</text>
                    }
                    else
                    {
                        <text>Login</text>
                    }
                </button>
            </div>

            <div style="text-align: center; margin-top: 16px;">
                <a @onclick="@(() => NavManager.NavigateTo("/register"))" style="color: #1890ff; cursor: pointer; text-decoration: underline;">Don't have an account? Register</a>
                <br />
                <a @onclick="@(() => NavManager.NavigateTo("/forgot-password"))" style="color: #1890ff; cursor: pointer; text-decoration: underline;">Forgot password?</a>
            </div>
        </EditForm>
    </Card>
</div>

@code {
    private readonly LoginModel _model = new();
    private bool _isLoading = false;
    private string _errorMessage = "";

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = "";

        try
        {
            var isValid = await Mediator.Send(new CheckUserViaPassword.Query
            {
                Username = _model.Username,
                Password = _model.Username,
            });

            if (isValid)
            {
                var redirectUrl = !string.IsNullOrEmpty(ReturnUrl) ? ReturnUrl : "/";
                NavManager.NavigateTo(redirectUrl, forceLoad: true);
            }
            else
            {
                _errorMessage = "Invalid login or password";
            }
        }
        catch (ValidationException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            _errorMessage = "Произошла непредвиденная ошибка";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private class LoginModel
    {
        [Required(ErrorMessage = "Username is required")]
        public string Username { get; set; } = "";

        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = "";
    }
}
