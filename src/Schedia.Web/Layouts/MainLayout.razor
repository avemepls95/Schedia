@inject NavigationManager NavigationManager
@using Avemepls.Security.Principal
@inherits LayoutComponentBase

<AuthorizeView>
    <Authorized>

        <Layout Style="min-height: 100vh;">
            <Sider Collapsible Collapsed="@_collapsed" CollapsedChanged="@OnCollapse" Width="250"
                   Theme="SiderTheme.Light">
                <a href="">
                    <div class="logo"></div>
                </a>
                <NavMenu></NavMenu>
            </Sider>
            <Content Class="site-layout-background" Style="padding: 24px; margin: 0; min-height: 280px;">
                @Body
            </Content>
        </Layout>

    </Authorized>
    <NotAuthorized>
        <Login/>
    </NotAuthorized>
</AuthorizeView>

@code{

    bool _collapsed;

    void OnCollapse(bool collapsed)
    {
        _collapsed = collapsed;
    }

    [Inject]
    public required IPrincipalAccessor PrincipalAccessor { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var user = await PrincipalAccessor.GetPrincipal();

            if (user.Identity?.IsAuthenticated != true)
            {
                NavigationManager.NavigateTo($"api/auth/oidc/sign-in?redirectUri={NavigationManager.Uri}", true);
            }
        }
    }

}