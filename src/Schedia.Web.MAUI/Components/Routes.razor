@using MudBlazor
@using Schedia.Web.Shared.Layouts

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<Router AppAssembly="@typeof(Routes).Assembly"
        AdditionalAssemblies="new[] { typeof(Schedia.Web.Shared._Imports).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(AppLayout)" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(AppLayout)">
            <p>Страница не найдена...</p>
        </LayoutView>
    </NotFound>
</Router>
