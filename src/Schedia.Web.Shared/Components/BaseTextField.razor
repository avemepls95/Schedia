@typeparam T
@using MudBlazor
@using System.Linq.Expressions

<MudTextField T="T"
              Value="@Value"
              ValueChanged="@OnValueChanged"
              Label="@Label"
              Placeholder="@Placeholder"
              HelperText="@HelperText"
              Variant="@Variant"
              Margin="@Margin"
              InputType="@CurrentInputType"
              Class="@CombinedClass"
              Style="@Style"
              For="@For"
              Disabled="@Disabled"
              ReadOnly="@ReadOnly"
              Required="@Required"
              RequiredError="@RequiredError"
              MaxLength="@MaxLength"
              Counter="@Counter"
              Immediate="@Immediate"
              DebounceInterval="@DebounceInterval"
              Adornment="@CurrentAdornment"
              AdornmentIcon="@CurrentAdornmentIcon"
              AdornmentColor="@AdornmentColor"
              OnAdornmentClick="@OnAdornmentClicked"
              OnBlur="@OnBlur"
              OnKeyDown="@OnKeyDown"
              OnKeyUp="@OnKeyUp"
              AutoFocus="@AutoFocus"
              Lines="@Lines"
              Clearable="@Clearable"
              OnClearButtonClick="@OnClearButtonClick" />

@code {
    // Value binding
    [Parameter] public T? Value { get; set; }
    [Parameter] public EventCallback<T> ValueChanged { get; set; }

    // Labels and text
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? HelperText { get; set; }

    // Appearance - with defaults
    [Parameter] public Variant Variant { get; set; } = Variant.Text;
    [Parameter] public Margin Margin { get; set; } = Margin.Normal;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }

    // Input type
    [Parameter] public InputType InputType { get; set; } = InputType.Text;

    // Validation
    [Parameter] public Expression<Func<T>>? For { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public string? RequiredError { get; set; }

    // State
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }

    // Constraints
    [Parameter] public int MaxLength { get; set; } = 524288;
    [Parameter] public int? Counter { get; set; }

    // Behavior
    [Parameter] public bool Immediate { get; set; }
    [Parameter] public double DebounceInterval { get; set; } = 0;
    [Parameter] public bool AutoFocus { get; set; }
    [Parameter] public int Lines { get; set; } = 1;
    [Parameter] public bool Clearable { get; set; }

    // Icons
    [Parameter] public string? StartIcon { get; set; }
    [Parameter] public string? EndIcon { get; set; }
    [Parameter] public Color AdornmentColor { get; set; } = Color.Default;

    // Password toggle
    [Parameter] public bool ShowPasswordToggle { get; set; } = true;

    // Events
    [Parameter] public EventCallback<FocusEventArgs> OnBlur { get; set; }
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyDown { get; set; }
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyUp { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClearButtonClick { get; set; }

    // Private state
    private bool _passwordVisible;

    private string CombinedClass => string.IsNullOrWhiteSpace(Class) ? "mb-4" : $"mb-4 {Class}";

    private InputType CurrentInputType
    {
        get
        {
            if (InputType == InputType.Password && _passwordVisible)
            {
                return InputType.Text;
            }
            return InputType;
        }
    }

    private Adornment CurrentAdornment
    {
        get
        {
            if (InputType == InputType.Password && ShowPasswordToggle)
            {
                return Adornment.End;
            }
            if (!string.IsNullOrEmpty(StartIcon))
            {
                return Adornment.Start;
            }
            if (!string.IsNullOrEmpty(EndIcon))
            {
                return Adornment.End;
            }
            return Adornment.None;
        }
    }

    private string? CurrentAdornmentIcon
    {
        get
        {
            if (InputType == InputType.Password && ShowPasswordToggle)
            {
                return _passwordVisible ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
            }
            if (!string.IsNullOrEmpty(StartIcon))
            {
                return StartIcon;
            }
            if (!string.IsNullOrEmpty(EndIcon))
            {
                return EndIcon;
            }
            return null;
        }
    }

    private async Task OnValueChanged(T value)
    {
        Value = value;
        await ValueChanged.InvokeAsync(value);
    }

    private void OnAdornmentClicked()
    {
        if (InputType == InputType.Password && ShowPasswordToggle)
        {
            _passwordVisible = !_passwordVisible;
        }
    }
}
