@page "/login"
@layout AnonymousLayout
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Authorization
@using Schedia.Auth.Domain.ViaPassword
@using Schedia.Web.Shared.Layouts
@using ValidationException = FluentValidation.ValidationException
@inject IMediator Mediator
@inject IAuthenticationService AuthService

<AuthorizeView>
    <Authorized>
        <RedirectToHome />
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height: 100vh;">
            <MudCard Style="max-width: 400px; width: 100%; padding: 20px;">
                <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-4">Login</MudText>

                <MudForm Model="@_model" @ref="@_form" Validation="@(_authValidator.ValidateValue)">

                    <BaseTextField T="string"
                                   @bind-Value="_model.Username"
                                   For="@(() => _model.Username)"
                                   Label="Username" />

                    <BaseTextField T="string"
                                   @bind-Value="_model.Password"
                                   For="@(() => _model.Password)"
                                   Label="Password"
                                   InputType="InputType.Password" />
                </MudForm>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
                }

                <MudButton ButtonType="ButtonType.Button"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Disabled="@(_isLoading)"
                           OnClick="@(async () => await HandleLogin())"
                           Class="mb-4">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                        <MudText Class="ml-2">Loading...</MudText>
                    }
                    else
                    {
                        <text>Login</text>
                    }
                </MudButton>

                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                    <div>Don't have an account?
                        <MudLink Href="/register" Color="Color.Primary">Register</MudLink>
                    </div>
                    <MudLink Href="/forgot-password" Color="Color.Primary">Forgot password?</MudLink>
                </MudStack>
            </MudCard>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

@code {
    private readonly Auth.Command _model = new();
    private bool _isLoading;
    private string _errorMessage = "";

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private readonly Auth.Validator _authValidator = new();

    private MudForm _form = null!;

    private async Task HandleLogin()
    {
        _isLoading = true;
        await _form.Validate();
        _isLoading = false;
        if (!_form.IsValid)
        {
            return;
        }

        _errorMessage = "";

        try
        {
            var tokenInformation = await Mediator.Send(new Auth.Command
            {
                Username = _model.Username,
                Password = _model.Password,
            });

            await AuthService.LoginAsync(tokenInformation, ReturnUrl);
        }
        catch (ValidationException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            _errorMessage = "Произошла непредвиденная ошибка";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
}
