@page "/forgot-password"
@layout AnonymousLayout
@attribute [AllowAnonymous]
@using Avemepls.Identity.DataAccess
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Schedia.Auth.Domain.ViaPassword
@using Schedia.Web.Shared.Layouts
@using Severity = MudBlazor.Severity
@using ValidationException = FluentValidation.ValidationException
@inject IMediator Mediator
@inject NavigationManager NavManager
@inject IDbContextFactory<IdentityDbContext> DbContextFactory

<AuthorizeView>
    <Authorized>
        <RedirectToHome/>
    </Authorized>
    <NotAuthorized>
        <div class="forgot-password-container" style="display: flex; justify-content: center; align-items: center; min-height: 100vh">
            <MudCard Title="Reset Password" Style="max-width: 400px; width: 100%; padding: 20px;">
                @if (!_emailSent)
                {
                    <MudForm Model="@_model" @ref="@_form" Validation="@(_authValidator.ValidateValue)">

                        <div style="padding: 8px; background: #e6f7ff; border: 1px solid #91d5ff; border-radius: 4px; color: #0050b3;">
                            Enter your email address and we'll send you a link to reset your password.
                        </div>

                        <BaseTextField T="string"
                                       @bind-Value="_model.Email"
                                       Label="Email"/>

                        <MudButton ButtonType="ButtonType.Button"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Disabled="@(_isLoading)"
                                   OnClick="@(async () => await HandleSubmit())"
                                   Class="mb-4">
                            @if (_isLoading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true"/>
                                <MudText Class="ml-2">Loading...</MudText>
                            }
                            else
                            {
                                <text>Send Reset Link</text>
                            }
                        </MudButton>

                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
                        }

                        <MudText Align="Align.Center">
                            <MudLink Href="/login" Color="Color.Primary">Back to login</MudLink>
                        </MudText>
                    </MudForm>
                }
                else
                {
                    <div style="text-align: center;">
                        <div style="margin-bottom: 16px; font-size: 48px; color: #52c41a;">✓</div>
                        <h3>Check Your Email</h3>
                        <p>We've sent password reset instructions.</p>
                        <MudButton @onclick="@(() => NavManager.NavigateTo("/login"))"
                                   Disabled="@(_isLoading)"
                                   style="margin-top: 16px; padding: 10px 20px; background: #1890ff; color: white; border: none; border-radius: 4px; cursor: pointer;">
                            Back to Login
                        </MudButton>
                    </div>
                }
            </MudCard>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private readonly RequestPasswordReset.Command _model = new();
    private bool _isLoading;
    private bool _emailSent;
    private string _errorMessage = "";

    private RequestPasswordReset.Validator _authValidator = null!;

    private MudForm _form = null!;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _authValidator = new RequestPasswordReset.Validator(DbContextFactory);
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        await _form.Validate();
        _isLoading = false;
        if (!_form.IsValid)
        {
            return;
        }

        _errorMessage = "";

        try
        {
            await Mediator.Send(new RequestPasswordReset.Command
            {
                Email = _model.Email,
            });

            _emailSent = true;
        }
        catch (ValidationException ex)
        {
            _errorMessage = ex.Message;
        }
        catch
        {
            _errorMessage = "Произошла непредвиденная ошибка";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

}
