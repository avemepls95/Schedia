@page "/reset-password"
@layout AnonymousLayout
@attribute [AllowAnonymous]
@using Avemepls.Identity.DataAccess
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Schedia.Web.Shared.Layouts
@using Severity = MudBlazor.Severity
@using FluentValidation
@using ValidationException = FluentValidation.ValidationException

@inject NavigationManager NavManager
@inject IMediator Mediator
@inject IDbContextFactory<IdentityDbContext> DbContextFactory

<AuthorizeView>
    <Authorized>
        <RedirectToHome/>
    </Authorized>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height: 100vh;">
            <MudCard Style="max-width: 400px; width: 100%; padding: 20px;">
                @if (!_passwordReset)
                {
                    <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-4">Set new password</MudText>
                    <MudForm @ref="@_form" Model="@_model" Validation="@(_validator.ValidateValue)">

                        <BaseTextField T="string"
                                       @bind-Value="_model.NewPassword"
                                       For="@(() => _model.NewPassword)"
                                       Label="New Password"
                                       InputType="InputType.Password"/>

                        <BaseTextField T="string"
                                       @bind-Value="_model.ConfirmPassword"
                                       For="@(() => _model.ConfirmPassword)"
                                       Label="Confirm Password"
                                       InputType="InputType.Password"/>

                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
                        }

                        <MudButton ButtonType="ButtonType.Button"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Disabled="@(_isLoading)"
                                   OnClick="@(async () => await HandleSubmit())"
                                   Class="mb-4">
                            @if (_isLoading)
                            {
                                <text>Loading...</text>
                            }
                            else
                            {
                                <text>Reset Password</text>
                            }
                        </MudButton>
                    </MudForm>
                }
                else
                {
                    <div style="text-align: center;">
                        <div style="margin-bottom: 16px; font-size: 48px; color: #52c41a;">✓</div>
                        <h3>Password Reset Successful</h3>
                        <p>Your password has been changed. You can now log in with your new password.</p>
                        <button @onclick="@(() => NavManager.NavigateTo("/login"))"
                                style="margin-top: 16px; padding: 10px 20px; background: #1890ff; color: white; border: none; border-radius: 4px; cursor: pointer;">
                            Go to Login
                        </button>
                    </div>
                }
            </MudCard>
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

@code {
    private readonly Command _model = new();
    private bool _isLoading;
    private bool _passwordReset;
    private string _errorMessage = "";

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private MudForm _form = null!;
    private Validator _validator = null!;

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(Token))
        {
            NavManager.NavigateTo("/forgot-password");
        }

        _validator = new Validator(DbContextFactory);
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        await _form.Validate();
        _isLoading = false;
        if (!_form.IsValid)
        {
            return;
        }

        _errorMessage = "";

        try
        {
            await Mediator.Send(new Schedia.Auth.Domain.ViaPassword.ResetPassword.Command
            {
                NewPassword = _model.NewPassword,
                Token = Token!
            });

            _passwordReset = true;
        }
        catch (ValidationException ex)
        {
            _errorMessage = ex.Message;
        }
        catch
        {
            _errorMessage = "Произошла непредвиденная ошибка";
        }
        finally
        {
            _isLoading = false;
        }
    }

    public class Command : Auth.Domain.ViaPassword.ResetPassword.Command
    {
        public string ConfirmPassword { get; set; }
    }

    public class Validator : Auth.Domain.ViaPassword.ResetPassword.Validator<Command>
    {
        public Validator(IDbContextFactory<IdentityDbContext> dbContextFactory) : base(dbContextFactory)
        {
            RuleFor(x => x.ConfirmPassword)
                .Equal(x => x.NewPassword)
                .WithMessage("Confirm password should be equivalent to password");
        }
    }

}
