[*.cs]

### Align

# Align multiline constructs
resharper_align_first_arg_by_paren = false

# Align even if the resulting indentation is too large
resharper_csharp_allow_far_alignment = false
resharper_allow_far_alignment = false

resharper_csharp_alignment_tab_fill_style = optimal_fill
resharper_alignment_tab_fill_style = optimal_fill

resharper_csharp_align_multiline_parameter = false
resharper_align_multiline_parameter = false
resharper_csharp_align_multiline_calls_chain = false
resharper_align_multiline_calls_chain = false
resharper_csharp_align_multiline_argument = false
resharper_align_multiline_argument = true

# XML Indent
resharper_xmldoc_indent_text = zero_indent

### BRACES

# Block under "case" label
resharper_csharp_case_block_braces = next_line

#### NEW LINES

# attribute always on new line
resharper_place_attribute_on_same_line = false

# After statements with child blocks
resharper_blank_lines_after_block_statements = 1

# Before multiline statements
resharper_csharp_blank_lines_before_multiline_statements = 1
resharper_blank_lines_before_multiline_statements = 1

# After multiline statements
resharper_csharp_blank_lines_after_multiline_statements = 1
resharper_blank_lines_after_multiline_statements = 1

# Blank lines in declarations
resharper_csharp_keep_blank_lines_in_declarations = 1
resharper_keep_blank_lines_in_declarations = 1

# new line before if
resharper_csharp_blank_lines_before_control_transfer_statements = 1
# new line after if
resharper_csharp_blank_lines_after_control_transfer_statements = 1

# new line before block of code
resharper_csharp_blank_lines_before_block_statements = 1
# new line after block of code
resharper_csharp_blank_lines_after_block_statements = 1

# Around multiline 'case' section in switch statement
resharper_csharp_blank_lines_around_multiline_case_section = 1

# Around single line property/event
resharper_csharp_blank_lines_around_single_line_property = 1
resharper_blank_lines_around_single_line_property = 1
resharper_csharp_blank_lines_around_property = 1
resharper_csharp_blank_lines_around_auto_property = 1
resharper_csharp_blank_lines_around_single_line_auto_property = 1

### LINE BREAKS

# Allow type constraints on the same line
resharper_csharp_place_type_constraints_on_same_line = false

# Place 'while' on a new line
resharper_csharp_new_line_before_while = true

# Place simple method on single line
resharper_place_simple_method_on_single_line = false
resharper_place_simple_blocks_on_single_line = false
resharper_place_simple_declaration_blocks_on_single_line = false

# Place simple embedded statement on the same line
resharper_place_simple_embedded_statement_on_same_line = false

# Wrap invocation arguments
resharper_csharp_wrap_arguments_style = chop_if_long
resharper_wrap_arguments_style = chop_if_long

# Max invocation arguments on a single line
resharper_csharp_max_invocation_arguments_on_line = 5
resharper_max_invocation_arguments_on_line = 5

# Prefer to wrap after '(' in invocation
resharper_csharp_wrap_after_invocation_lpar = false
resharper_wrap_after_invocation_lpar = false


# Prefer wrap before '=>' followed by expressions
resharper_csharp_wrap_before_arrow_with_expressions = true
resharper_wrap_before_arrow_with_expressions = true

## Arrangement of method signatures
resharper_csharp_wrap_parameters_style = chop_if_long

# Max formal parameters on a single line
resharper_csharp_max_formal_parameters_on_line = 5
resharper_max_formal_parameters_on_line = 5

# refer to wrap after '(' in declaration
resharper_csharp_wrap_after_declaration_lpar = true

# Wrap chained method calls
resharper_csharp_wrap_chained_method_calls = chop_if_long

# Prefer wrap before '?' and ':' in ternary expressions
resharper_csharp_wrap_before_ternary_opsigns = true

# Wrap ternary expression
resharper_wrap_ternary_expr_style = chop_always

# After file header comment
resharper_csharp_blank_lines_after_start_comment = 0

# Keep max blank lines in code
resharper_csharp_keep_blank_lines_in_code = 1

# blank line before comment
resharper_blank_lines_before_single_line_comment = 1

# csharp_style_var_for_built_in_types=true:silent
# csharp_style_var_when_type_is_apparent=true:silent
# csharp_style_var_elsewhere=true:silent

#############
# Analyzers #
#############

# Automatically sort and remove usings
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true

# general settings applied to all source files
# Source folder contains additional .editorconfig with overrides
#
# enable all analyzers by default
# https://docs.microsoft.com/en-us/dotnet/fundamentals/code-analysis/quality-rules/
dotnet_analyzer_diagnostic.severity = error
dotnet_code_quality.api_surface = all
dotnet_code_quality.enable_platform_analyzer_on_pre_net5_target = true

# Parameter names should match base declaration
dotnet_diagnostic.CA1725.severity = warning

# Инициализируйте статические поля ссылочных типов при объявлении
dotnet_diagnostic.ca1810.severity = error

# Пометьте члены как статические
dotnet_diagnostic.ca1822.severity = error

# Do not declare visible instance fields
dotnet_diagnostic.CA1051.severity = error

# Package not found
dotnet_diagnostic.NU1603.severity = error

# "Exists" method should be used instead of the "Any"
dotnet_diagnostic.S6605.severity = error

# "Find" method should be used instead of the "FirstOrDefault"
dotnet_diagnostic.S6602.severity = error

# "TrueForAll" method should be used instead of the "All"
dotnet_diagnostic.S6603.severity = error

# Тип может быть запечатанным, так как у него нет подтипов в содержащей его сборке и он невидим извне
dotnet_diagnostic.CA1852.severity = error

# Private classes which are not derived in the current assembly should be marked as 'sealed'
dotnet_diagnostic.S3260.severity = error

# Unused route parameter
dotnet_diagnostic.ASP0018.severity = error

# Change return type to 'void'; not a single caller uses the returned value
dotnet_diagnostic.S3241.severity = error

# Code analysis suppression should have justification
dotnet_diagnostic.SA1404.severity = error

# ToDateTime should specify DateTimeKind
dotnet_diagnostic.QC001.severity = error

# Fix this implementation of 'IDisposable' to conform to the dispose pattern
dotnet_diagnostic.S3881.severity = error

# Complete the assertion
dotnet_diagnostic.S2970.severity = error

# Поля, не являющиеся константами, не должны быть видимыми
dotnet_diagnostic.CA2211.severity = error

# Перегрузка метода "XmlSerializer.Deserialize" потенциально небезопасна
dotnet_diagnostic.CA5369.severity = error

# Use an immutable collection or reduce the accessibility of the non-private readonly field 'Dict'
dotnet_diagnostic.S3887.severity = error

# Экземпляры ValueTask, возвращаемые из вызовов методов, необходимо непосредственно ожидать
dotnet_diagnostic.CA2012.severity = error

# Test methods should not be skipped
dotnet_diagnostic.xUnit1004.severity = none

# The member referenced by the MemberData attribute returns untyped data rows, such as object[]
dotnet_diagnostic.xUnit1042.severity = error

# Operator should not appear at the end of a line
dotnet_diagnostic.SA1003.severity = none

#should not raise for overridden property with base getter
dotnet_diagnostic.S2376.severity = error

# Identifiers should not have incorrect suffix
dotnet_diagnostic.CA1711.severity = none

# T is not used in the interface
dotnet_diagnostic.S2326.severity = error

# Remove deprecated rule
dotnet_diagnostic.S2353.severity = error

# Fields must be declared with private access. Use properties to expose fields
dotnet_diagnostic.SA1401.severity = error

# Implicit parameterless constructor widens the scope of the base class constructor
dotnet_diagnostic.S2094.severity = error

# Method overloads should be grouped together we see some false positives
dotnet_diagnostic.S4136.severity = error

# Deprecated code should be removed
dotnet_diagnostic.S1133.severity = error

# Logging in a catch clause should pass the caught exception as a parameter
dotnet_diagnostic.S6667.severity = error

dotnet_diagnostic.S127.severity = error

dotnet_diagnostic.S1075.severity = error

# when using ?? with an empty string
dotnet_diagnostic.S2583.severity = error

# This nested ternary operation can be converted into a tuple
dotnet_diagnostic.S3358.severity = error

# Method calls should not resolve ambiguously to overloads with "params"
dotnet_diagnostic.S3220.severity = error

# Specify StringComparison for correctness
dotnet_diagnostic.CA1310.severity = none

# укажите StringComparison для ясности
dotnet_diagnostic.SA1307.severity = error

# Specify a culture or use an invariant version
dotnet_diagnostic.SA1311.severity = error

#  Use concrete types when possible for improved performance
dotnet_diagnostic.CA1859.severity = error

# Template should be a static expression is a warning that the log message doesn't have a consistent structure due to being interpolated or concatenated
dotnet_diagnostic.CA2254.severity = error

dotnet_diagnostic.S1117.severity = error

dotnet_diagnostic.S3267.severity = error

dotnet_diagnostic.xUnit1026.severity = error

# Use ordinal StringComparison
dotnet_diagnostic.CA1309.severity = none

# Either log this exception and handle it, or rethrow it with some contextual information
dotnet_diagnostic.S2139.severity = none

# Update this logger to use its enclosing type
dotnet_diagnostic.S6672.severity = error

# Provide the "DateTimeKind" when creating this object
dotnet_diagnostic.S6562.severity = error

# Use a format provider when parsing date and time
dotnet_diagnostic.S6580.severity = error

# Use an immutable collection or reduce the accessibility of the public static field
dotnet_diagnostic.S2386.severity = error

# Member Should can not be intercepted. Only interface members and virtual, overriding, and abstract members can be intercepted
dotnet_diagnostic.NS1000.severity = error

# Value type property used as input in a controller action should be nullable, required or annotated with the JsonRequiredAttribute to avoid under-posting
dotnet_diagnostic.S6964.severity = error

# Use .Should() instead of ?.Should()
dotnet_diagnostic.FAA0001.severity = error

##
## StyleCop.Analyzers
##


# CA1716: Identifiers should not match keywords
dotnet_diagnostic.CA1716.severity = none

# Use the LoggerMessage delegates
dotnet_diagnostic.ca1848.severity = none

# Using directive should appear within a namespace declaration
dotnet_diagnostic.sa1200.severity = none

# XML comment analysis is disabled due to project configuration
dotnet_diagnostic.sa0001.severity = none

# The file header is missing or not located at the top of the file
dotnet_diagnostic.sa1633.severity = none

# Use string.Empty for empty strings
dotnet_diagnostic.sa1122.severity = none

# Variable '_' should begin with lower-case letter
dotnet_diagnostic.sa1312.severity = none

# CS1591 Missing XML comment for publicly visible type or member 'TestController'
dotnet_diagnostic.cs1591.severity = none

# Parameter '_' should begin with lower-case letter
dotnet_diagnostic.sa1313.severity = none

# Elements should be documented
dotnet_diagnostic.sa1600.severity = none

# Prefix local calls with this
dotnet_diagnostic.sa1101.severity = none

# 'public' members should come before 'private' members
dotnet_diagnostic.sa1202.severity = none

# Comments should contain text
dotnet_diagnostic.sa1120.severity = none

dotnet_diagnostic.sa1028.severity = error

# Constant fields should appear before non-constant fields
dotnet_diagnostic.sa1203.severity = none

# Field '_blah' should not begin with an underscore
dotnet_diagnostic.sa1309.severity = none

# Use trailing comma in multi-line initializers
dotnet_diagnostic.sa1413.severity = none

# A method should not follow a class
dotnet_diagnostic.sa1201.severity = none

# Elements should be separated by blank line
dotnet_diagnostic.sa1516.severity = none

# The parameter spans multiple lines
dotnet_diagnostic.sa1118.severity = none

# Static members should appear before non-static members
dotnet_diagnostic.sa1204.severity = none

# Put constructor initializers on their own line
dotnet_diagnostic.sa1128.severity = none

# Opening braces should not be preceded by blank line
dotnet_diagnostic.sa1509.severity = none

# The parameter should begin on the line after the previous parameter
dotnet_diagnostic.sa1115.severity = none

# File name should match first type name
dotnet_diagnostic.sa1649.severity = none

# File may only contain a single type
dotnet_diagnostic.sa1402.severity = warning

# Enumeration items should be documented
dotnet_diagnostic.sa1602.severity = none

# Element should not be on a single line
dotnet_diagnostic.sa1502.severity = error

# Closing parenthesis should not be preceded by a space
dotnet_diagnostic.sa1009.severity = none

# Closing parenthesis should be on line of last parameter
dotnet_diagnostic.sa1111.severity = none

# Braces should not be ommitted
dotnet_diagnostic.sa1503.severity = none

# The line endings at the end of a file do not match the settings for the project
dotnet_diagnostic.sa1518.severity = warning

